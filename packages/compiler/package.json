{
  "name": "@valibot/compiler",
  "description": "The official compiler for Valibot",
  "version": "0.1.0",
  "license": "MIT",
  "author": "Fabian Hiller",
  "homepage": "https://valibot.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-circle/valibot"
  },
  "keywords": [
    "valibot",
    "compiler",
    "optimization",
    "build-time"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/plugin/vite.d.mts",
        "default": "./dist/plugin/vite.mjs"
      },
      "require": {
        "types": "./dist/plugin/vite.d.cts",
        "default": "./dist/plugin/vite.cjs"
      }
    },
    "./rollup": {
      "import": {
        "types": "./dist/plugin/rollup.d.mts",
        "default": "./dist/plugin/rollup.mjs"
      },
      "require": {
        "types": "./dist/plugin/rollup.d.cts",
        "default": "./dist/plugin/rollup.cjs"
      }
    },
    "./rolldown": {
      "import": {
        "types": "./dist/plugin/rolldown.d.mts",
        "default": "./dist/plugin/rolldown.mjs"
      },
      "require": {
        "types": "./dist/plugin/rolldown.d.cts",
        "default": "./dist/plugin/rolldown.cjs"
      }
    },
    "./esbuild": {
      "import": {
        "types": "./dist/plugin/esbuild.d.mts",
        "default": "./dist/plugin/esbuild.mjs"
      },
      "require": {
        "types": "./dist/plugin/esbuild.d.cts",
        "default": "./dist/plugin/esbuild.cjs"
      }
    },
    "./webpack": {
      "import": {
        "types": "./dist/plugin/webpack.d.mts",
        "default": "./dist/plugin/webpack.mjs"
      },
      "require": {
        "types": "./dist/plugin/webpack.d.cts",
        "default": "./dist/plugin/webpack.cjs"
      }
    },
    "./rspack": {
      "import": {
        "types": "./dist/plugin/rspack.d.mts",
        "default": "./dist/plugin/rspack.mjs"
      },
      "require": {
        "types": "./dist/plugin/rspack.d.cts",
        "default": "./dist/plugin/rspack.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest --typecheck",
    "lint": "eslint \"src/**/*.ts*\" && tsc --noEmit",
    "lint.fix": "eslint \"src/**/*.ts*\" --fix",
    "format": "prettier --write ./src",
    "format.check": "prettier --check ./src",
    "build": "tsdown"
  },
  "dependencies": {
    "magic-string": "^0.30.0",
    "oxc-parser": "^0.72.0",
    "oxc-walker": "^0.2.0",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "tsdown": "^0.16.6",
    "typescript": "^5.9.3",
    "valibot": "^1.3.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "4.0.13"
  },
  "peerDependencies": {
    "valibot": "^1.3.0"
  }
}
